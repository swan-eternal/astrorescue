# Godot 4+ specific ignores
.godot/
.import/

# Imported translations (auto-generated)
*.translation

# Godot-specific output
.godot/

# Stale hand-authored level scene, no longer used by the project —
# LevelLoader reads data/levels/level_NN.json, not this .tscn. Godot
# keeps regenerating it because the path is in its recent-scenes
# list (see .godot/editor/editor_layout.cfg). The file is harmless on
# disk; this entry just keeps `git status` clean.
scenes/level_01.tscn

# Project planning + build notes (Astro-Rescue.md, Astro-RescueV2.md,
# future V3, etc.) — working documents authored during development
# (architecture, lessons learned, release checklists) rather than
# game-content shipped with the binary. Keep them on disk for the
# developer, but don't track or release them.
Astro-Rescue*.md

# Tuning + release-prep docs — local working references, not shipped.
# `tuningparameters.md` lists gameplay knobs and editor bounds so they
# can be tuned without spelunking the codebase. `itchio-html-release.md`
# is a one-time checklist for the first web release. Add a new line
# here for any future developer-only doc of the same shape.
tuningparameters.md
itchio-html-release.md

# Godot export output — written next to the project root by the
# Windows/Web export presets. Generated artifacts, not source. The
# `AstroRescueV02.{exe,pck,console.exe}` files were tracked by
# accident from an earlier export and were removed from tracking
# in commit `3b08244`. These patterns keep them out going forward.
*.pck
*.exe
*.zip
